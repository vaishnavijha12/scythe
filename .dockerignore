# Keep the build context lean — only ship what the wheel needs.

.git
.github
.gitignore
.gitattributes

# Local virtualenvs and Python build caches
.venv
venv
env
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.mypy_cache
.ruff_cache

# Existing build outputs (we rebuild inside the image)
build
dist
*.egg-info

# Editor / IDE
.idea
.vscode
.DS_Store

# Repo-only assets that would just bloat the image
demo
logs
tests
CONTRIBUTING.md
CHANGELOG.md
CLAUDE.md
.claude
